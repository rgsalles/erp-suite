{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=ErpSuiteDb;User Id=sa;Password=Your_strong_password123;Encrypt=False;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Issuer": "ErpSuite",
    "Audience": "ErpSuite.Web",
    "Secret": "development-secret-key-for-local-erp-suite-change-me",
    "ExpiresMinutes": 480
  },
  "Database": {
    "AutoCreate": true,
    "Seed": true,
    "DockerSqlServer": {
      "Enabled": true,
      "ComposeFile": "docker-compose.yml",
      "ProjectName": "erp-suite",
      "ServiceName": "sqlserver",
      "Services": [
        "sqlserver",
        "rabbitmq"
      ],
      "ContainerName": "erp-suite-sqlserver",
      "Host": "localhost",
      "Port": 1433,
      "StartupTimeoutSeconds": 90
    }
  },
  "RabbitMq": {
    "Enabled": true,
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "ExchangeName": "erp.events",
    "LowStockQueueName": "erp.low-stock-alerts",
    "RetryDelaySeconds": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
